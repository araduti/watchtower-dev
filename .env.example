# =============================================================================
# Watchtower — environment variables (example)
# =============================================================================
#
# Copy this file to .env and fill in any blanks. The defaults below are
# SAFE FOR LOCAL DEVELOPMENT ONLY. Production values come from your secrets
# vault, never from a file in the repo.
#
# Variables marked REQUIRED have no default and must be set before
# `docker compose up` or `bun run dev` will work.
#
# Variables marked CHANGE-FOR-PROD have dev defaults that are NOT secure
# and must be replaced for any non-local environment.
#
# =============================================================================

# -----------------------------------------------------------------------------
# DATABASE
# -----------------------------------------------------------------------------
# Watchtower uses two database connection strings — one for the runtime
# application (which cannot bypass RLS) and one for migrations and seeds
# (which has DDL rights). The roles are created by the Postgres init
# script on first container start.
#
# CHANGE-FOR-PROD: all three passwords below are dev defaults. Replace them
# in production with values from your secrets vault.

POSTGRES_SUPERUSER_PASSWORD=postgres-dev-password-change-me
WATCHTOWER_APP_PASSWORD=app-dev-password-change-me
WATCHTOWER_MIGRATE_PASSWORD=migrate-dev-password-change-me

# Used by the application at runtime. Connects as watchtower_app.
DATABASE_URL=postgresql://watchtower_app:app-dev-password-change-me@localhost:5432/watchtower?schema=public

# Used by `prisma migrate deploy`, `prisma db push`, and the seed runner.
# Connects as watchtower_migrate.
DATABASE_MIGRATE_URL=postgresql://watchtower_migrate:migrate-dev-password-change-me@localhost:5432/watchtower?schema=public

# -----------------------------------------------------------------------------
# AUTHENTICATION (Better Auth)
# -----------------------------------------------------------------------------
# REQUIRED. The session signing secret. Generate a fresh one per environment:
#   openssl rand -base64 32
BETTER_AUTH_SECRET=dev-only-secret-replace-with-openssl-rand-base64-32
BETTER_AUTH_URL=http://localhost:3000

# -----------------------------------------------------------------------------
# OBJECT STORAGE (Garage S3)
# -----------------------------------------------------------------------------
# Endpoint of the local Garage instance. The dev compose file binds it to
# port 3900. Bucket and access keys are created on first start by the
# Garage init job.
GARAGE_S3_ENDPOINT=http://localhost:3900
GARAGE_S3_REGION=garage
GARAGE_S3_BUCKET=watchtower-evidence
GARAGE_S3_ACCESS_KEY=dev-access-key
GARAGE_S3_SECRET_KEY=dev-secret-key

# -----------------------------------------------------------------------------
# INNGEST (workflow orchestration)
# -----------------------------------------------------------------------------
# In dev, the Inngest dev server runs in the compose stack and is stateless.
# These keys are placeholders for dev — the dev server doesn't validate them.
INNGEST_EVENT_KEY=dev-event-key
INNGEST_SIGNING_KEY=dev-signing-key

# INNGEST_DEV overrides the dev server URL. The Inngest client already
# auto-detects dev mode from NODE_ENV, so this variable is only needed
# if the dev server runs on a non-default address (default: http://127.0.0.1:8288).
# INNGEST_DEV=http://localhost:8288

# -----------------------------------------------------------------------------
# CREDENTIAL ENCRYPTION
# -----------------------------------------------------------------------------
# AES-256-GCM key used to encrypt/decrypt tenant credentials at rest.
# Must be exactly 64 hex characters (32 bytes). Generate a fresh one:
#   openssl rand -hex 32
#
# CHANGE-FOR-PROD: the key below is a dev default. It is PUBLIC (committed
# to version control) and must NEVER be used in production or staging.
# Replace it with a value from your secrets vault.
WATCHTOWER_CREDENTIAL_KEY=be3cf4a297b4f3c7daf5b8993a9b0965dd240bdafec34a2d290c5bbf0980227c

# -----------------------------------------------------------------------------
# AUDIT LOG SIGNING
# -----------------------------------------------------------------------------
# Path to the Ed25519 private key used to sign audit events. In dev, generate
# one with:
#   openssl genpkey -algorithm Ed25519 -out ./secrets/audit-signing-key.pem
# In production, this path points to a secret mounted from the secrets vault.
# The PRIVATE key NEVER appears in this file or in version control.
AUDIT_SIGNING_KEY_PATH=./secrets/audit-signing-key.pem

# -----------------------------------------------------------------------------
# STRIPE (metered billing)
# -----------------------------------------------------------------------------
# Use Stripe test keys in dev. Production keys come from the secrets vault.
STRIPE_SECRET_KEY=sk_test_replace_me
STRIPE_WEBHOOK_SECRET=whsec_replace_me

# -----------------------------------------------------------------------------
# GITHUB APP (custom policy sync)
# -----------------------------------------------------------------------------
# REQUIRED for customer plugin evaluation. Create a GitHub App in your org
# settings, install it on a test repo, and put the App ID and private key here.
# The private key path is treated the same way as the audit signing key.
GITHUB_APP_ID=
GITHUB_APP_PRIVATE_KEY_PATH=./secrets/github-app-key.pem

# -----------------------------------------------------------------------------
# PLUGIN SANDBOX (Firecracker microVMs)
# -----------------------------------------------------------------------------
# Controls how customer-authored plugin evaluators are executed.
#
# WATCHTOWER_SANDBOX_MODE:
#   - "production" (default) — Firecracker microVMs, requires /dev/kvm
#   - "dev" — same-process execution, NO isolation (dev only, loud warning)
#
# The Firecracker paths are only needed when SANDBOX_MODE is "production".
# macOS contributors: set SANDBOX_MODE=dev (KVM is not available on macOS).
WATCHTOWER_SANDBOX_MODE=dev
FIRECRACKER_BIN_PATH=/usr/local/bin/firecracker
FIRECRACKER_KERNEL_PATH=/opt/watchtower/vmlinux
FIRECRACKER_ROOTFS_PATH=/opt/watchtower/rootfs.ext4
PLUGIN_TIMEOUT_SECONDS=30
PLUGIN_MEMORY_MIB=128
PLUGIN_VCPU_COUNT=1

# -----------------------------------------------------------------------------
# APPLICATION
# -----------------------------------------------------------------------------
NODE_ENV=development
PORT=3000
LOG_LEVEL=debug

# -----------------------------------------------------------------------------
# OBSERVABILITY (optional in dev)
# -----------------------------------------------------------------------------
# OpenTelemetry exporter. Leave commented out in dev unless you're testing
# the observability path.
# OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
# OTEL_SERVICE_NAME=watchtower-dev
