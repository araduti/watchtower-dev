{
  "name": "watchtower-dev",
  "private": true,
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "dev": "bun --filter '@watchtower/web' dev",
    "build": "bun --filter '@watchtower/web' build",
    "test": "vitest run",
    "test:unit": "vitest run --project unit",
    "test:watch": "vitest watch",
    "typecheck": "tsc --noEmit",
    "db:push": "prisma db push",
    "db:migrate": "DATABASE_URL=$DATABASE_MIGRATE_URL prisma migrate deploy",
    "db:migrate:dev": "DATABASE_URL=$DATABASE_MIGRATE_URL prisma migrate dev",
    "db:studio": "DATABASE_URL=$DATABASE_MIGRATE_URL prisma studio",
    "db:generate": "prisma generate",
    "db:seed": "DATABASE_URL=$DATABASE_MIGRATE_URL bun run prisma/seeds/index.ts",
    "db:rls": "psql \"$DATABASE_MIGRATE_URL\" -f prisma/migrations/001_rls_setup.sql",
    "db:reset": "docker compose -f docker-compose.dev.yml down -v && docker compose -f docker-compose.dev.yml up -d"
  },
  "devDependencies": {
    "@types/bun": "^1.2.4",
    "@types/pg": "^8",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "vitest": "^4.1.4"
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "dependencies": {
    "@microsoft/microsoft-graph-client": "^3.0.7",
    "@prisma/adapter-pg": "^7.7.0",
    "@prisma/client": "^7",
    "@radix-ui/react-avatar": "^1.1.11",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-navigation-menu": "^1.2.14",
    "@radix-ui/react-popover": "^1.1.15",
    "@radix-ui/react-scroll-area": "^1.2.10",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-switch": "^1.2.6",
    "@radix-ui/react-tabs": "^1.1.13",
    "@radix-ui/react-toggle": "^1.1.10",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@tailwindcss/postcss": "^4.2.2",
    "@tanstack/react-query": "^5.99.0",
    "@trpc/client": "^11.16.0",
    "@trpc/react-query": "^11.16.0",
    "@trpc/server": "^11.16.0",
    "@types/node": "^22.13.5",
    "better-auth": "^1.6.2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "inngest": "^4.2.2",
    "lucide-react": "^1.8.0",
    "next": "^16.2.3",
    "next-themes": "0.4.6",
    "pg": "^8",
    "postcss": "^8.5.10",
    "prisma": "^7",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4.2.2",
    "tw-animate-css": "1.3.4",
    "zod": "^4.3.6"
  }
}
